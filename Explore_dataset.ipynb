   "source": [
    "strong_corr_vars = [\"dns_qtype\", \"src_port\", \"dst_port\", \"dns_qclass\", \"src_pkts\"]\n",
    "\n",
    "\n",
    "'''\n",
    "normalize so that predictors measured on different scales could be compared in the same chart.\n",
    "normalization used: min-max\n",
    "    converts to a 0-1 scale, where 0 represents the minimum value in that column and 1 represents the maximum value.\n",
    "normalized value = (original value - column minimum) / (column maximum - column minimum)\n",
    "'''\n",
    "normalized = df.copy()\n",
    "\n",
    "normalized[strong_corr_vars] = (\n",
    "    df[strong_corr_vars] - df[strong_corr_vars].min()\n",
    ") / (\n",
    "    df[strong_corr_vars].max() - df[strong_corr_vars].min()\n",
    ")\n",
    "\n",
    "# calculate the average normalized value of each predictor for each label\n",
    "normalized_mean_by_label = normalized.groupby(\"label\")[strong_corr_vars].mean().T\n",
    "\n",
    "display(normalized_mean_by_label)\n",
    "\n",
    "ax = normalized_mean_by_label.plot(kind=\"bar\", figsize=(12, 6))\n",
    "\n",
    "for container in ax.containers:\n",
    "    ax.bar_label(container, fmt=\"%.3f\")\n",
    "\n",
    "plt.title(\"Normalized Mean Predictor Values by Label\")\n",
    "plt.xlabel(\"Predictor\")\n",
    "plt.ylabel(\"Normalized Mean Value\")\n",
    "plt.xticks(rotation=0)\n",
    "plt.legend(title=\"Label\")\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
