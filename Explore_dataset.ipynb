   "source": [
    "## Outlier\n",
    "\n",
    "checks numeric columns for outliers using the IQR rule.\n",
    "\n",
    "A value is flagged as an outlier if it is:\n",
    "- below Q1 - 1.5 × IQR, or\n",
    "- above Q3 + 1.5 × IQR"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 19,
   "id": "fb66f369-944f-4e43-9507-718bee2f2a02",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Numeric columns  ['src_port', 'dst_port', 'duration', 'src_bytes', 'dst_bytes', 'missed_bytes', 'src_pkts', 'src_ip_bytes', 'dst_pkts', 'dst_ip_bytes', 'dns_qclass', 'dns_qtype', 'dns_rcode', 'http_request_body_len', 'http_response_body_len', 'http_status_code', 'label']\n"
     ]
    }
   ],
   "source": [
    "numeric_cols = df.select_dtypes(include=[np.number]).columns.tolist()\n",
    "print(\"Numeric columns \", numeric_cols)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 27,
   "id": "d04e51eb",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Column  src_port  outliers included\n",
      "Column  dst_port  outliers included\n",
      "Column  duration  outliers included\n",
      "Column  src_bytes  outliers included\n",
      "Column  dst_bytes  outliers included\n",
      "Column  missed_bytes  outliers included\n",
      "Column  src_pkts  outliers included\n",
      "Column  src_ip_bytes  outliers included\n",
      "Column  dst_pkts  outliers included\n",
      "Column  dst_ip_bytes  outliers included\n",
      "Column  dns_qclass  outliers included\n",
      "Column  dns_qtype  outliers included\n",
      "Column  dns_rcode  outliers included\n",
      "Column  http_request_body_len  outliers included\n",
      "Column  http_response_body_len  outliers included\n",
      "Column  http_status_code  outliers included\n"
     ]
    }
   ],
   "source": [
    "numeric_cols = [i for i in numeric_cols if i!='label']\n",
    "for c in numeric_cols:\n",
    "    percentiles = df[c].quantile([0.25,0.50,0.75])\n",
    "    iqr = percentiles[0.75] - percentiles[0.25]\n",
    "    lower_bound = percentiles[0.25] - (1.5*iqr)\n",
    "    upper_bound = percentiles[0.75] + (1.5*iqr)\n",
    "    df[c+'_is_outlier'] = (df[c]<lower_bound) | (df[c]>upper_bound)\n",
    "    print(\"Column \",c,\" outliers included\")"
   ]
  },
